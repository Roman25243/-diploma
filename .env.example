# Flask Configuration
SECRET_KEY=generate_random_secret_key_here_min_32_chars
DEBUG=False

# Database Configuration
# SQLite (для розробки):
# DATABASE_URL=sqlite:///database.db

# PostgreSQL (для production/Heroku):
# На Heroku це встановлюється автоматично при додаванні PostgreSQL addon
# DATABASE_URL=postgresql://username:password@host:port/database_name

# Email Configuration (вибрати один сервіс)

## Опція 1: Gmail (простіше для тесту)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-NOT-regular-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

## Опція 2: SendGrid (рекомендується для production)
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=SG.your_sendgrid_api_key
# MAIL_DEFAULT_SENDER=noreply@cinemabook.com

## Опція 3: MailTrap (для тестування)
# MAIL_SERVER=smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=your-mailtrap-username
# MAIL_PASSWORD=your-mailtrap-password
# MAIL_DEFAULT_SENDER=noreply@cinemabook.com

# Online Payments
PAYMENT_ONLINE_ENABLED=True
PAYMENT_PROVIDER=stripe
PAYMENT_CURRENCY=UAH
PAYMENT_APP_BASE_URL=http://127.0.0.1:5000

# Для Heroku змініть на:
# PAYMENT_APP_BASE_URL=https://your-app-name.herokuapp.com
# PAYMENT_SUCCESS_URL=https://your-app-name.herokuapp.com/app/profile?payment=success
# PAYMENT_CANCEL_URL=https://your-app-name.herokuapp.com/app/profile?payment=cancel

# Stripe (якщо використовуєте)
PAYMENT_SUCCESS_URL=http://127.0.0.1:5000/app/profile?payment=success
PAYMENT_CANCEL_URL=http://127.0.0.1:5000/app/profile?payment=cancel
STRIPE_SECRET_KEY=sk_test_your_test_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Production Stripe keys (встановіть на Heroku via config vars):
# STRIPE_SECRET_KEY=sk_live_your_live_secret_key
# STRIPE_PUBLISHABLE_KEY=pk_live_your_live_publishable_key
# STRIPE_WEBHOOK_SECRET=whsec_your_live_webhook_secret
#
# Outlook:
# MAIL_SERVER=smtp-mail.outlook.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@outlook.com
# MAIL_PASSWORD=your-password
